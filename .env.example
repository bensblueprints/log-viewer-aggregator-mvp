# Logbin configuration — copy to .env and edit

# Port the web app listens on
PORT=5347

# UDP port for the syslog listener (0 disables it)
SYSLOG_PORT=5514

# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=change-me

# SQLite database location
DB_PATH=./data/logbin.db

# SMTP for email alerts (optional — webhook alerts work without SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
